# OpenAI API Configuration
OPENAI_API_KEY=
OPENAI_BASE_URL="https://api.deepseek.com/v1" # Or your custom base URL
# 通用默认模型：用于 DM 对话、剧情生成、Revision 等
OPENAI_MODEL=
# 剧情列表 Agent
PLOT_OUTLINE_MODEL=
# 剧情简介 Agent
PLOT_SYNOPSIS_MODEL=
# RevisionAgent（改剧情 + 梗概）
PLOT_REVISION_MODEL=

# RAG API Configuration （避免 LLM API 不提供嵌入，如 OpenRouter）
## 嵌入模型配置，若未提供 API Key 或 Base URL 将回落到 OPENAI_* 变量
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_BASE_URL=
RAG_EMBEDDING_MODEL=text-embedding-3-large

# 开发设置（以下环境变量部署时不应该调整，这些参数应该在缺失时也能使用缺省配置正常运行）

# Database Configuration
## For SQLite (local development):
DATABASE_URL="sqlite:///data/data.db"
## For PostgreSQL (production - example):
# DATABASE_URL="postgresql://user:password@host:port/database"

# Logging Configuration
## Log Level Configuration
LOG_LEVEL=INFO
## Log File Path
LOG_PATH="logs/"

# Application Port
PORT=8080

## Data File Path
DND_DATA_FILE_PATH="assets/dnd_data.json"
SYSTEM_PROMPT_FILE_PATH="assets/system_rule.json"
OPTIONS_PROMPT_FILE_PATH="assets/options_prompt.json"

# LangChain Progressive Integration Configuration
## Enable LangChain Memory system (default: False for backward compatibility)
USE_LANGCHAIN_MEMORY=False
## Memory window size for long conversations (0 = full memory, >0 = windowed memory)
LANGCHAIN_MEMORY_WINDOW_SIZE=0
## Enable D&D conversation chain (experimental, default: False)
USE_CONVERSATION_CHAIN=False
## Auto-optimize memory for long conversations (default: True)
AUTO_OPTIMIZE_MEMORY=True

# Options Generation Configuration
## Enable/disable options generation feature (default: True)
SUGGEST_OPTIONS_ENABLED=True
## Number of conversation rounds to use for generating options (default: 5)
SUGGEST_OPTIONS_HISTORY_LIMIT=5
## Specific model for options generation (optional, uses main model if not set)
SUGGEST_OPTIONS_MODEL=

# Laminar Configuration
## LMNR_PROJECT_API_KEY=
## LMNR_BASE_URL="http://localhost"
## LMNR_HTTP_PORT=8000
## LMNR_GRPC_PORT=8001

# RAG Vectorization Configuration
## 总开关：False 时跳过向量化与相关检查
RAG_ENABLED=True
## Dungeon Master's Guide markdown source; default指向仓库自带文件
RAG_DM_SOURCE_PATH="assets/DM.md"
## ChromaDB 持久化目录
RAG_CHROMA_DIR="data/chromadb"
## 向量集合名称
RAG_CHROMA_COLLECTION=dm_guide_2024

## 嵌入批量与并发控制
RAG_EMBEDDING_BATCH_SIZE=16
RAG_EMBEDDING_CONCURRENCY=4

## 文本切分参数
RAG_SPLIT_CHUNK_SIZE=4000
RAG_SPLIT_CHUNK_OVERLAP=400
## 头部层级定义，格式：标记=别名，逗号分隔
RAG_SPLIT_HEADERS="#=h1,##=h2,###=h3,####=h4,#####=h5"

## 检索参数
RAG_SEARCH_TOP_K=4